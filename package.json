{
  "name": "@hasagi/extended",
  "private": true,
  "version": "0.2.11",
  "description": "A library that makes using the League of Legends client API (LCU) easy.",
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:package": "npm run build && publint ./dist && attw --pack ./dist",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "npm run check:package && cd ./dist && npm publish --access public",
    "update-deps": "npm i @hasagi/core@latest"
  },
  "author": "dysolix",
  "license": "MIT",
  "keywords": [
    "hasagi"
  ],
  "dependencies": {
    "@hasagi/core": "0.7.0",
    "tiny-typed-emitter": "2.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^20.19.42",
    "eslint": "^10.5.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dysolix/hasagi-extended.git"
  }
}
